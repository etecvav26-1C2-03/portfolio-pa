* Descrição: 
* Ler o peso de uma pessoa em quilos, calcular e mostrar o peso em
gramas.
*/





programa {
  funcao inicio() {
    real peso
    escreva("Seu Peso em quilos >>> ")
    leia(peso)
    escreva(peso * 1000, " em gramas")
  }
}
